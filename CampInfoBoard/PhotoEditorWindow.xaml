<Window x:Class="CampInfoBoard.PhotoEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Photo"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Image:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="ImagePathBox" Grid.Row="0" Grid.Column="1" Margin="0,4"/>
        <Button Content="Browse..." Grid.Row="0" Grid.Column="2" Margin="8,4,0,4" Click="Browse_Click"/>


        <Image x:Name="PreviewImage"
            Grid.Row="1"
            Grid.Column="1"
            Grid.ColumnSpan="2"
            Width="220"
            Height="130"
            Margin="0,6,0,10"
            Stretch="Uniform"/>
        
        <TextBlock Text="Caption:" 
                   Grid.Row="2" Grid.Column="0" 
                   VerticalAlignment="Center"/>
        <TextBox x:Name="CaptionBox" 
                 Grid.Row="2" Grid.Column="1" 
                 Grid.ColumnSpan="2" 
                 MaxLength="100"
                 Margin="0,4"/>

        <TextBlock Text="Credit:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="CreditBox" 
                 Grid.Row="3" Grid.Column="1" 
                 Grid.ColumnSpan="2" 
                 MaxLength="100"
                 Margin="0,4"/>

        <TextBlock Text="Expiry:" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"/>
        <DatePicker x:Name="ExpiryPicker" Grid.Row="4" Grid.Column="1" Margin="0,4"/>

        <CheckBox x:Name="ActiveCheckBox"
                  Grid.Row="5"
                  Grid.Column="1"
                  Margin="0,8"
                  Content="Active"/>

        <StackPanel Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="Save" Width="80" Margin="0,0,8,0" Click="Save_Click"/>
            <Button Content="Cancel" Width="80" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
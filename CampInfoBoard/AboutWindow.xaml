<Window x:Class="CampInfoBoard.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Camp Info Board"
        Width="420"
        Height="260"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <StackPanel Margin="24">
        <TextBlock Text="Camp Info Board"
                   FontSize="26"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <TextBlock x:Name="VersionText"
                   FontSize="16"
                   Margin="0,0,0,18"/>

        <TextBlock Text="Public display software for campground information boards."
                   TextWrapping="Wrap"
                   FontSize="15"
                   Margin="0,0,0,24"/>

        <Button Content="OK"
                Width="90"
                HorizontalAlignment="Right"
                Click="Ok_Click"/>
    </StackPanel>
</Window>
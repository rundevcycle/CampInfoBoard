<Window x:Class="CampInfoBoard.AnnouncementEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
        xmlns:converters="clr-namespace:CampInfoBoard.Converters"
        Title="Announcement"
        Width="700"
        Height="620"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <converters:ImagePathToBitmapConverter x:Key="ImagePathToBitmapConverter"/>
    </Window.Resources>

    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">

            <Button Content="OK"
                    Width="90"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="Ok_Click"/>

            <Button Content="Cancel"
                    Width="90"
                    IsCancel="True"/>
        </StackPanel>

        <Grid Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>



            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Start Date" Margin="0,0,8,8"/>
                <TextBox Grid.Row="0" Grid.Column="1"
                    Margin="0,0,0,8"
                     Text="{Binding StartDateText, UpdateSourceTrigger=LostFocus}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Start Time" Margin="0,0,8,8"/>
                <TextBox Grid.Row="1" Grid.Column="1"
                     Text="{Binding StartTimeText, UpdateSourceTrigger=LostFocus}"
                        Margin="0,0,0,8"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="End Date" Margin="0,0,8,8"/>
                <TextBox Grid.Row="2" Grid.Column="1"
                     Text="{Binding EndDateText, UpdateSourceTrigger=LostFocus}"
                     Margin="0,0,0,8"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="End Time" Margin="0,0,8,8"/>
                <TextBox Grid.Row="3" Grid.Column="1"
                     Text="{Binding EndTimeText, UpdateSourceTrigger=LostFocus}"
                     Margin="0,0,0,8"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Priority" Margin="0,0,8,8"/>
                <StackPanel Orientation="Horizontal" 
                            Grid.Row="4" Grid.Column="1">
                    <TextBox 
                         Text="{Binding Priority, UpdateSourceTrigger=PropertyChanged}"
                        Width="60"
                        
                         Margin="0,0,8,8"/>
                    <TextBlock VerticalAlignment="Center"
                             FontSize="10"
                             FontStyle="Italic"
                            Margin="0,0,0,8"
                             Text="Bigger number means higher priority"/>
                </StackPanel>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Title" Margin="0,0,8,8"/>
                <TextBox Grid.Row="5" Grid.Column="1"
                     Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,8"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Body" Margin="0,4,8,8"/>
                <TextBox Grid.Row="6" Grid.Column="1"
                     Text="{Binding BodyText, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"/>
            </Grid>

            <StackPanel Grid.Column="1" Margin="20,0,0,0">
                <TextBlock Text="Image"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8"/>

                <StackPanel Margin="0,0,0,8">
                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,8">
                        <Button Content="Browse"
                            Width="70"
                            Margin="0,0,8,0"
                            Padding="8,4"
                            Click="BrowseImage_Click"/>
                        <Button Content="Clear"
                            Width="70"
                            Padding="8,4"
                            Click="ClearImage_Click"/>
                    </StackPanel>

                    <!-- Filename -->
                    <Border Background="#11000000"
                        BorderBrush="#33000000"
                        BorderThickness="1"
                        Padding="6">
                        <TextBlock TextWrapping="Wrap"
                            x:Name="ImagePathText"
                            Opacity="0.75">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding ImagePath}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ImagePath}" Value="">
                                            <Setter Property="Text" Value="No image selected"/>
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ImagePath}" Value="{x:Null}">
                                            <Setter Property="Text" Value="No image selected"/>
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <Border Height="170"
                    Background="#22000000"
                    BorderBrush="#33000000"
                    BorderThickness="1">
                    <Image x:Name="ImagePreview"
                        Source="{Binding ImagePath, Converter={StaticResource ImagePathToBitmapConverter}}"
                        Stretch="Uniform"/>
                </Border>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
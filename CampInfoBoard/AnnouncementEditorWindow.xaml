<Window x:Class="CampInfoBoard.AnnouncementEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Announcement"
        Width="700"
        Height="620"
        WindowStartupLocation="CenterOwner">

    <DockPanel Margin="16">

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">

            <Button Content="OK"
                    Width="90"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="Ok_Click"/>

            <Button Content="Cancel"
                    Width="90"
                    IsCancel="True"/>
        </StackPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Start Date" Margin="0,0,8,8"/>
            <TextBox Grid.Row="0" Grid.Column="1"
                     Text="{Binding StartDateText, UpdateSourceTrigger=LostFocus}"
                     Margin="0,0,16,8"/>

            <TextBlock Grid.Row="0" Grid.Column="2" Text="Start Time" Margin="0,0,8,8"/>
            <TextBox Grid.Row="0" Grid.Column="3"
                     Text="{Binding StartTimeText, UpdateSourceTrigger=LostFocus}"
                     Margin="0,0,0,8"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="End Date" Margin="0,0,8,8"/>
            <TextBox Grid.Row="1" Grid.Column="1"
                     Text="{Binding EndDateText, UpdateSourceTrigger=LostFocus}"
                     Margin="0,0,16,8"/>

            <TextBlock Grid.Row="1" Grid.Column="2" Text="End Time" Margin="0,0,8,8"/>
            <TextBox Grid.Row="1" Grid.Column="3"
                     Text="{Binding EndTimeText, UpdateSourceTrigger=LostFocus}"
                     Margin="0,0,0,8"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Priority" Margin="0,0,8,8"/>
            <TextBox Grid.Row="2" Grid.Column="1"
                     Text="{Binding Priority, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,16,8"/>

            <TextBlock Grid.Row="2" Grid.Column="2" Text="Image" Margin="0,0,8,8"/>
            <DockPanel Grid.Row="2" Grid.Column="3" Margin="0,0,0,8">
                <Button Content="Browse"
                        DockPanel.Dock="Right"
                        Width="75"
                        Margin="8,0,0,0"
                        Click="BrowseImage_Click"/>
                <TextBox Text="{Binding ImagePath, UpdateSourceTrigger=PropertyChanged}"/>
            </DockPanel>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Title" Margin="0,0,8,8"/>
            <TextBox Grid.Row="3" Grid.Column="1"
                     Grid.ColumnSpan="3"
                     Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,8"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Body" Margin="0,4,8,8"/>
            <TextBox Grid.Row="4" Grid.Column="1"
                     Grid.ColumnSpan="3"
                     Text="{Binding BodyText, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"/>
        </Grid>
    </DockPanel>
</Window>
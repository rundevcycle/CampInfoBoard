<Window x:Class="CampInfoBoard.DisplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:CampInfoBoard.Converters"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="Black">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibility"/>
        <converters:ImagePathToBitmapConverter x:Key="ImagePathToBitmapConverter"/>
    </Window.Resources>

    <Grid>

        <!-- ================= BACKGROUND ================= -->
        <Image Source="{Binding BackgroundImagePath}"
               Stretch="UniformToFill"
               Opacity="0.5"/>

        <!-- readability overlay -->
        <Rectangle Fill="Black" Opacity="0.45"/>

        <!-- ================= MAIN LAYOUT ================= -->
        <Grid Margin="32">

            <Grid.ColumnDefinitions>
                <!-- LEFT INFO STRIP -->
                <ColumnDefinition Width="420"/>
                <!-- MAIN CONTENT -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ================= LEFT PANEL ================= -->
            <StackPanel Grid.Column="0"
                        VerticalAlignment="Top">

                <!-- TIME (ANCHOR) -->
                <StackPanel Margin="0,0,0,28">
                    <TextBlock Text="{Binding CurrentTime, StringFormat='{}{0:dddd, MMMM d}'}"
                               FontSize="22"
                               Foreground="White"
                               Opacity="0.9"/>

                    <TextBlock Text="{Binding CurrentTime, StringFormat='{}{0:hh:mm tt}'}"
                               FontSize="44"
                               FontWeight="SemiBold"
                               Foreground="White"/>
                </StackPanel>

                <!-- WEATHER BLOCK -->
                <StackPanel Margin="0,0,0,24">
                    <TextBlock Text="Weather"
                               FontSize="18"
                               Foreground="White"
                               Opacity="0.8"
                               Margin="0,0,0,8"/>

                    <ItemsControl ItemsSource="{Binding Weather}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,6">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Image Source="{Binding Icon}"
                                               Width="32"
                                               Height="32"
                                               Margin="0,0,10,0"/>
                                        <StackPanel>
                                            <TextBlock Text="{Binding TempDisplay}"
                                                       FontSize="18"
                                                       Foreground="White"/>
                                            <TextBlock Text="{Binding FeelsLikeDisplay}"
                                                       FontSize="14"
                                                       Foreground="LightGray"
                                                       Opacity="0.8"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- TIDES -->
                <StackPanel Margin="0,0,0,20"
                            Visibility="{Binding Settings.ShowTides, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="Tides"
                               FontSize="18"
                               Foreground="White"
                               Opacity="0.8"
                               Margin="0,0,0,6"/>

                    <TextBlock Text="{Binding HighTideDisplay}"
                               Foreground="White"/>
                    <TextBlock Text="{Binding LowTideDisplay}"
                               Foreground="White"
                               Opacity="0.9"/>
                </StackPanel>

                <!-- SUN + UV + RADIO (GROUPED INFO BLOCK) -->
                <StackPanel Margin="0,0,0,10">

                    <!-- SUN -->
                    <StackPanel Margin="0,0,0,14"
                                Visibility="{Binding Settings.ShowSun, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="Sun"
                                   FontSize="18"
                                   Foreground="White"
                                   Opacity="0.8"
                                   Margin="0,0,0,6"/>

                        <TextBlock Text="{Binding SunriseDisplay}"
                                   Foreground="White"/>
                        <TextBlock Text="{Binding SunsetDisplay}"
                                   Foreground="White"
                                   Opacity="0.9"/>
                    </StackPanel>

                    <!-- UV -->
                    <StackPanel Margin="0,0,0,14"
                                Visibility="{Binding Settings.ShowUV, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="UV Index"
                                   FontSize="18"
                                   Foreground="White"
                                   Opacity="0.8"
                                   Margin="0,0,0,6"/>

                        <TextBlock Text="{Binding UVDisplay}"
                                   FontSize="16"
                                   Foreground="White"/>
                    </StackPanel>

                    <!-- RADIO -->
                    <StackPanel Visibility="{Binding Radio.Enabled, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="FM Broadcast"
                                   FontSize="18"
                                   Foreground="White"
                                   Opacity="0.8"
                                   Margin="0,0,0,6"/>

                        <TextBlock Text="{Binding Radio.EnglishFrequency, StringFormat='EN {0} MHz'}"
                                   Foreground="White"
                                   Visibility="{Binding Radio.EnglishFrequency, Converter={StaticResource NullToVisibility}}"/>

                        <TextBlock Text="{Binding Radio.FrenchFrequency, StringFormat='FR {0} MHz'}"
                                   Foreground="White"
                                   Visibility="{Binding Radio.FrenchFrequency, Converter={StaticResource NullToVisibility}}"/>
                    </StackPanel>

                </StackPanel>

            </StackPanel>

            <!-- ================= MAIN CONTENT AREA ================= -->
            <Grid Grid.Column="1"
                  Margin="40,0,0,0">

                <!-- ================= SCHEDULE ================= -->
                <Grid Visibility="{Binding IsScheduleVisible, Converter={StaticResource BoolToVisibility}}">

                    <ScrollViewer VerticalScrollBarVisibility="Hidden">
                        <ItemsControl ItemsSource="{Binding FilteredSchedule}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>

                                    <Border Margin="0,10"
                                            Padding="16"
                                            Background="#22000000"
                                            CornerRadius="10">

                                        <StackPanel>

                                            <TextBlock Text="{Binding TimeRange}"
                                                       FontSize="18"
                                                       Foreground="#9AD0FF"/>

                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="48"
                                                       FontWeight="SemiBold"
                                                       Foreground="White"
                                                       Margin="0,4,0,0"/>

                                            <TextBlock Text="{Binding Location}"
                                                       FontSize="16"
                                                       Foreground="LightGray"
                                                       Opacity="0.9"/>

                                            <TextBlock Text="{Binding Speaker}"
                                                       FontSize="16"
                                                       Foreground="LightGray"
                                                       Opacity="0.9"/>

                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="16"
                                                       Foreground="White"
                                                       TextWrapping="Wrap"
                                                       Opacity="0.95"
                                                       Margin="0,6,0,0"/>

                                        </StackPanel>
                                    </Border>

                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                </Grid>

                <!-- ================= ANNOUNCEMENTS ================= -->
                <Grid Visibility="{Binding IsAnnouncementVisible, Converter={StaticResource BoolToVisibility}}">

                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Width="900">

                        <TextBlock Text="{Binding CurrentAnnouncement.Title}"
                                   FontSize="40"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   TextAlignment="Center"
                                   Margin="0,0,0,20"/>

                        <Image Source="{Binding CurrentAnnouncement.ImagePath}"
                               Height="260"
                               Stretch="Uniform"
                               Margin="0,0,0,20"/>

                        <TextBlock Text="{Binding CurrentAnnouncement.BodyText}"
                                   FontSize="26"
                                   Foreground="White"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Opacity="0.95"/>

                    </StackPanel>

                </Grid>

                <!-- ================= PHOTO ================= -->
                <Grid Visibility="{Binding IsPhotoVisible, Converter={StaticResource BoolToVisibility}}">

                    <Image Source="{Binding CurrentPhoto.ImagePath, Converter={StaticResource ImagePathToBitmapConverter}}"
                        Stretch="Uniform">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPhotoFallbackVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>

                    <!-- Fallback if photos aren't available. -->
                    <Border Background="#AA111111"
                        CornerRadius="12"
                        Padding="30"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPhotoFallbackVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <StackPanel>
                            <TextBlock Text="No Active Photos"
                                Foreground="White"
                                FontSize="36"
                                FontWeight="Bold"
                                HorizontalAlignment="Center" />

                            <TextBlock Text="Add photos or mark existing photos as Active."
                                Foreground="#DDFFFFFF"
                                FontSize="18"
                                Margin="0,10,0,0"
                                HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- bottom caption overlay -->
                    <Border VerticalAlignment="Bottom"
                            Height="180">

                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasCurrentPhotoText}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#00000000" Offset="0"/>
                                <GradientStop Color="#88000000" Offset="0.25" />
                                <GradientStop Color="#EE000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>

                        <Grid VerticalAlignment="Stretch"
                              Margin="24">

                            <StackPanel VerticalAlignment="Bottom">

                                <TextBlock Text="{Binding CurrentPhoto.Caption}"
                                    FontSize="30"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    TextWrapping="Wrap"/>

                                <TextBlock Text="{Binding CurrentPhoto.Credit}"
                                    FontSize="16"
                                    Foreground="#DDFFFFFF"
                                    Margin="0,6,0,0"
                                    TextWrapping="Wrap">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentPhoto.Credit}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding CurrentPhoto.Credit}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>

                </Grid>

            </Grid>

        </Grid>
    </Grid>
</Window>
<Window x:Class="CampInfoBoard.DisplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:CampInfoBoard.Converters"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="Black">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibility"/>
        <converters:ImagePathToBitmapConverter x:Key="ImagePathToBitmapConverter"/>
        <converters:UVIndexToBrushConverter x:Key="UVIndexToBrushConverter"/>
        <converters:ScheduleBackgroundConverter x:Key="ScheduleBackgroundConverter"/>
        <converters:ScheduleBorderConverter x:Key="ScheduleBorderConverter"/>
        <converters:ScaleValueConverter x:Key="ScaleValueConverter"/>

        <!-- Display text styles -->
        <SolidColorBrush x:Key="DisplayTextBrush" Color="White"/>
        <SolidColorBrush x:Key="DisplayMutedTextBrush" Color="#DDFFFFFF"/>
        <SolidColorBrush x:Key="DisplayAccentTextBrush" Color="#9AD0FF"/>
        <SolidColorBrush x:Key="DisplayCardBrush" Color="#33000000"/>
        <SolidColorBrush x:Key="DisplayStrongCardBrush" Color="#44000000"/>
        <SolidColorBrush x:Key="DisplaySeparatorBrush" Color="#40FFFFFF"/>


        <Style x:Key="DisplayTinyTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize"
                Value="{Binding DataContext.Settings.DisplayFontScale,
                            RelativeSource={RelativeSource AncestorType=Window},
                            Converter={StaticResource ScaleValueConverter},
                            ConverterParameter=20}"/>
            <Setter Property="Foreground" Value="{StaticResource DisplayMutedTextBrush}"/>
        </Style>

        <Style x:Key="DisplayTinySubtleTextStyle"
                TargetType="TextBlock"
                BasedOn="{StaticResource DisplayTinyTextStyle}">
            <Setter Property="Opacity" Value="0.75"/>
        </Style>

        <Style x:Key="DisplayAccentTinyTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource DisplayTinyTextStyle}">
            <Setter Property="Foreground" Value="{StaticResource DisplayAccentTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="DisplayLabelTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize"
                Value="{Binding DataContext.Settings.DisplayFontScale,
                            RelativeSource={RelativeSource AncestorType=Window},
                            Converter={StaticResource ScaleValueConverter},
                            ConverterParameter=24}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource DisplayAccentTextBrush}"/>
        </Style>

        <Style x:Key="DisplaySoftLabelTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource DisplayLabelTextStyle}">
            <Setter Property="Foreground" Value="{StaticResource DisplayMutedTextBrush}"/>
        </Style>

        <Style x:Key="DisplayMetaTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize"
                Value="{Binding DataContext.Settings.DisplayFontScale,
                            RelativeSource={RelativeSource AncestorType=Window},
                            Converter={StaticResource ScaleValueConverter},
                            ConverterParameter=28}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource DisplayTextBrush}"/>
        </Style>

        <Style x:Key="DisplayMutedMetaTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource DisplayMetaTextStyle}">
            <Setter Property="Foreground" Value="{StaticResource DisplayMutedTextBrush}"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>
        <Style x:Key="DisplayAccentMetaTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource DisplayMetaTextStyle}">
            <Setter Property="Foreground" Value="{StaticResource DisplayAccentTextBrush}"/>
        </Style>

        <Style x:Key="DisplayBodyTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize"
                Value="{Binding DataContext.Settings.DisplayFontScale,
                            RelativeSource={RelativeSource AncestorType=Window},
                            Converter={StaticResource ScaleValueConverter},
                            ConverterParameter=36}"/>
            <Setter Property="Foreground" Value="{StaticResource DisplayTextBrush}"/>
        </Style>

        <Style x:Key="DisplayLargeBodyTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource DisplayBodyTextStyle}">
            <Setter Property="FontSize"
                    Value="{Binding DataContext.Settings.DisplayFontScale,
                            RelativeSource={RelativeSource AncestorType=Window},
                            Converter={StaticResource ScaleValueConverter},
                            ConverterParameter=40}"/>
        </Style>
        <Style x:Key="DisplayValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize"
                Value="{Binding DataContext.Settings.DisplayFontScale,
                            RelativeSource={RelativeSource AncestorType=Window},
                            Converter={StaticResource ScaleValueConverter},
                            ConverterParameter=40}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource DisplayTextBrush}"/>
        </Style>
        
        <Style x:Key="DisplayCaptionTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource DisplayValueTextStyle}">
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="DisplayTemperatureTextStyle"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="{Binding DataContext.Settings.DisplayFontScale,
                            RelativeSource={RelativeSource AncestorType=Window},
                            Converter={StaticResource ScaleValueConverter},
                            ConverterParameter=48}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource DisplayTextBrush}"/>
        </Style>

        <Style x:Key="DisplayTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize"
                Value="{Binding DataContext.Settings.DisplayFontScale,
                            RelativeSource={RelativeSource AncestorType=Window},
                            Converter={StaticResource ScaleValueConverter},
                            ConverterParameter=54}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource DisplayTextBrush}"/>
        </Style>

        <Style x:Key="DisplayBannerTextStyle"
                TargetType="TextBlock"
                BasedOn="{StaticResource DisplayMetaTextStyle}">
            <Setter Property="Foreground" Value="{StaticResource DisplayAccentTextBrush}"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>


        <Style x:Key="PanelCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource DisplayCardBrush}"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style x:Key="LargePanelCardStyle"
            TargetType="Border"
            BasedOn="{StaticResource PanelCardStyle}">
            <Setter Property="Padding" Value="28"/>
        </Style>

        <Style x:Key="StrongPanelCardStyle"
            TargetType="Border"
            BasedOn="{StaticResource PanelCardStyle}">
            <Setter Property="Background" Value="{StaticResource DisplayStrongCardBrush}"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="34"/>
        </Style>
    </Window.Resources>

    <Grid Background="{Binding Settings.BackgroundColor}">
        
        <!-- ================= BACKGROUND ================= -->
        <Image Source="{Binding BackgroundImagePath, Converter={StaticResource ImagePathToBitmapConverter}}"
                Stretch="UniformToFill"
                Opacity="0.5">
            <Image.Style>
                <Style TargetType="Image">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPhotoVisible}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding BackgroundImagePath}" Value="">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding BackgroundImagePath}"
                             Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Image.Style>
        </Image>

        <!-- readability overlay -->
        <Rectangle Fill="Black"
           Opacity="0.45">
            <Rectangle.Style>
                <Style TargetType="Rectangle">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPhotoVisible}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Rectangle.Style>
        </Rectangle>

        <!-- ================= MAIN LAYOUT ================= -->
        <Grid Margin="32">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPhotoVisible}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.ColumnDefinitions>
                <!-- LEFT INFO STRIP -->
                <ColumnDefinition Width="420"/>
                <!-- MAIN CONTENT -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ================= LEFT PANEL ================= -->
            <StackPanel Grid.Column="0"
                        VerticalAlignment="Top">

                <!-- TIME (ANCHOR) -->
                <Border Style="{StaticResource PanelCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding CurrentTime, StringFormat='{}{0:dddd, MMMM d}'}"
                                   Style="{StaticResource DisplayLabelTextStyle}"/>

                        <TextBlock Text="{Binding CurrentTime, StringFormat='{}{0:h:mm tt}'}"
                                   Style="{StaticResource DisplayTitleTextStyle}"/>
                    </StackPanel>
                </Border>

                
                <!-- WEATHER BLOCK -->
                <Border>
                    <Border.Style>
                        <Style TargetType="Border"
                            BasedOn="{StaticResource PanelCardStyle}">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Settings.ShowWeather}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding HasItems, ElementName=DashboardWeatherItems}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <ItemsControl x:Name="DashboardWeatherItems"
                                      ItemsSource="{Binding DisplayWeather}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="84"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="70"/>
                                        </Grid.ColumnDefinitions>

                                        <Image Grid.Column="0"
                                            Source="{Binding IconPath}"
                                            Width="72"
                                            Height="72"
                                            Margin="0,0,10,0"/>

                                        <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DateLabel}"
                                                       Style="{StaticResource DisplayAccentTinyTextStyle}"/>

                                            <TextBlock Text="{Binding TemperatureDisplay}"
                                                       Style="{StaticResource DisplayMetaTextStyle}"/>

                                            <TextBlock Text="{Binding FeelsLikeDisplay}"
                                                Style="{StaticResource DisplayTinySubtleTextStyle}"
                                                Visibility="{Binding HasFeelsLike, Converter={StaticResource BoolToVisibility}}"/>
                                        </StackPanel>

                                        <Border Grid.Column="2"
                                            Width="64"
                                            Height="64"
                                            CornerRadius="32"
                                            Background="{Binding UVIndex, Converter={StaticResource UVIndexToBrushConverter}}"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Right"
                                            Visibility="{Binding HasUV, Converter={StaticResource BoolToVisibility}}">
                                            <StackPanel HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                                <TextBlock Text="UV"
                                                    FontSize="14"
                                                    FontWeight="Bold"
                                                    Foreground="Black"
                                                    HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding UVIndex}"
                                                    FontSize="32"
                                                    FontWeight="Bold"
                                                    Foreground="Black"
                                                    HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                
                <!-- SUN TIMES -->
                <Border Style="{StaticResource PanelCardStyle}"
                        Visibility="{Binding Settings.ShowSun, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,4">
                                <Image Source="pack://application:,,,/Assets/WeatherIcons/sunrise.png"
                                    Width="64"
                                    Height="48"
                                    Margin="0,0,14,0"/>
                                <TextBlock Text="{Binding TodaySun.Sunrise, StringFormat={}{0:h:mm tt}}"
                                           Style="{StaticResource DisplayMetaTextStyle}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <Image Source="pack://application:,,,/Assets/WeatherIcons/sunset.png"
                                    Width="64"
                                    Height="48"
                                    Margin="0,0,14,0"/>
                                <TextBlock Text="{Binding TodaySun.Sunset, StringFormat={}{0:h:mm tt}}"
                                           Style="{StaticResource DisplayMetaTextStyle}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>


                <!-- TIDES -->
                <Border Style="{StaticResource PanelCardStyle}"
                        Visibility="{Binding Settings.ShowTides, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl ItemsSource="{Binding DisplayTides}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <TextBlock Text="{Binding SeparatorLabel}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock"
                                                   BasedOn="{StaticResource DisplayAccentTinyTextStyle}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,4">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <Image Source="{Binding IconPath}"
                                            Width="64"
                                            Height="48"
                                            Margin="0,0,14,0"/>
                                        <TextBlock Text="{Binding TimeDisplay}"
                                                   Style="{StaticResource DisplayMetaTextStyle}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>


                <!-- RADIO FREQUENCIES -->
                <Border Style="{StaticResource PanelCardStyle}"
                        Visibility="{Binding Radio.Enabled, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <!-- RADIO -->
                        <StackPanel>
                            <TextBlock Text="FM Radio"
                                       Style="{StaticResource DisplayAccentTinyTextStyle}"
                                       Margin="0,0,0,6"/>

                            <TextBlock Text="{Binding Radio.EnglishFrequency, StringFormat='EN {0} MHz'}"
                                       Style="{StaticResource DisplayMetaTextStyle}"
                                       Visibility="{Binding Radio.EnglishFrequency, Converter={StaticResource NullToVisibility}}"/>

                            <TextBlock Text="{Binding Radio.FrenchFrequency, StringFormat='FR {0} MHz'}"
                                       Style="{StaticResource DisplayMetaTextStyle}"
                                       Visibility="{Binding Radio.FrenchFrequency, Converter={StaticResource NullToVisibility}}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>


            <!-- ================= MAIN CONTENT AREA ================= -->
            <Grid Grid.Column="1"
                  Margin="40,0,0,0">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>


                <!-- ================= TOP BANNER ================= -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Settings.ShowBanner}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Settings.BannerPosition}" Value="Bottom">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Settings.BannerText}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <StackPanel>
                        <!-- Banner text -->
                        <TextBlock Text="{Binding Settings.BannerText}"
                                   Style="{StaticResource DisplayBannerTextStyle}"
                                   Margin="0,0,0,8"/>

                        <!-- Separator line -->
                        <Border Height="2"
                            Background="{StaticResource DisplaySeparatorBrush}"
                            HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Grid>
                

                <Grid Grid.Row="1">
                    <!-- ================= SCHEDULE ================= -->
                    <Grid Visibility="{Binding IsScheduleVisible, Converter={StaticResource BoolToVisibility}}">

                        <ScrollViewer VerticalScrollBarVisibility="Hidden">
                            <ItemsControl ItemsSource="{Binding FilteredSchedule}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                            Padding="16"
                                            Background="{Binding IsHappeningNow, Converter={StaticResource ScheduleBackgroundConverter}}"
                                            BorderBrush="{Binding IsHappeningNow, Converter={StaticResource ScheduleBorderConverter}}"
                                            BorderThickness="3"
                                            CornerRadius="10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="220"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- TIME -->
                                                <StackPanel Grid.Column="0"
                                                VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding DisplayDayLabel}"
                                                               Style="{StaticResource DisplayLabelTextStyle}"/>

                                                    <TextBlock Text="{Binding DisplayStartTime}"
                                                               Style="{StaticResource DisplayValueTextStyle}"
                                                               Margin="0,4,0,0"/>

                                                    <TextBlock Text="{Binding DisplayEndTime}"
                                                               Style="{StaticResource DisplaySoftLabelTextStyle}"
                                                               Margin="0,2,0,0"
                                                               Visibility="{Binding DisplayEndTime, Converter={StaticResource NullToVisibility}}"/>
                                                </StackPanel>
                                                
                                                <!-- DETAILS -->
                                                <StackPanel Grid.Column="1"
                                                    Margin="20,0,0,0">

                                                    <TextBlock Text="{Binding Title}"
                                                               Style="{StaticResource DisplayTitleTextStyle}" />

                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Location}"
                                                                   Style="{StaticResource DisplayAccentMetaTextStyle}"
                                                                   Margin="0,6,0,0"
                                                                   Visibility="{Binding Location, Converter={StaticResource NullToVisibility}}"/>

                                                        <TextBlock Text=" • "
                                                                   Margin="6,6,6,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock"
                                                                       BasedOn="{StaticResource DisplayAccentMetaTextStyle}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Location}" Value="">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Speaker}" Value="">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding Speaker}"
                                                                   Style="{StaticResource DisplayAccentMetaTextStyle}"
                                                                   Margin="0,6,24,0"/>
                                                    </StackPanel>

                                                    <TextBlock Text="{Binding Description}"
                                                               Style="{StaticResource DisplayBodyTextStyle}"
                                                               TextWrapping="Wrap"
                                                               Margin="0,10,0,0"
                                                               Opacity="0.95"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                    </Grid>


                    <!-- ================= WEATHER ================= -->
                    <Grid Visibility="{Binding IsWeatherVisible, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel VerticalAlignment="Top"
                        HorizontalAlignment="Center"
                        Width="1100">

                            <ItemsControl ItemsSource="{Binding DisplayWeather}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="28"
                                                Style="{StaticResource LargePanelCardStyle}"
                                                CornerRadius="14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="180"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="150"/>
                                                </Grid.ColumnDefinitions>

                                                <Image Grid.Column="0"
                                                Source="{Binding IconPath}"
                                                Width="152"
                                                Height="152"
                                                VerticalAlignment="Top"/>

                                                <StackPanel Grid.Column="1"
                                                Margin="20,0,0,0">

                                                    <TextBlock Text="{Binding DateLabel}"
                                                               Style="{StaticResource DisplayLabelTextStyle}"/>

                                                    <TextBlock Text="{Binding TemperatureDisplay}"
                                                               Style="{StaticResource DisplayTemperatureTextStyle}"/>

                                                    <TextBlock Text="{Binding FeelsLikeDisplay}"
                                                               Style="{StaticResource DisplayMutedMetaTextStyle}"
                                                               Visibility="{Binding HasFeelsLike, Converter={StaticResource BoolToVisibility}}"/>

                                                    <TextBlock Text="{Binding Description}"
                                                               Style="{StaticResource DisplayBodyTextStyle}"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap"/>

                                                    <TextBlock Text="{Binding WindDisplay}"
                                                               Style="{StaticResource DisplayMutedMetaTextStyle}"
                                                               Visibility="{Binding HasWind, Converter={StaticResource BoolToVisibility}}"/>

                                                    <TextBlock Text="{Binding PrecipitationDisplay}"
                                                               Style="{StaticResource DisplayMutedMetaTextStyle}"
                                                               Visibility="{Binding PrecipitationDisplay, Converter={StaticResource NullToVisibility}}"/>
                                                </StackPanel>

                                                <Border Grid.Column="2"
                                                        Width="116"
                                                        Height="116"
                                                        CornerRadius="58"
                                                        Background="{Binding UVIndex, Converter={StaticResource UVIndexToBrushConverter}}"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Right"
                                                        Visibility="{Binding HasUV, Converter={StaticResource BoolToVisibility}}">
                                                    <StackPanel HorizontalAlignment="Center"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="UV"
                                                                   FontSize="22"
                                                                   FontWeight="Bold"
                                                                   Foreground="Black"
                                                                   HorizontalAlignment="Center"/>
                                                        <TextBlock Text="{Binding UVIndex}"
                                                                   FontSize="46"
                                                                   FontWeight="Bold"
                                                                   Foreground="Black"
                                                                   HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>


                    <!-- ================= ANNOUNCEMENTS ================= -->
                    <Grid Visibility="{Binding IsAnnouncementVisible, Converter={StaticResource BoolToVisibility}}">

                        <Border Style="{StaticResource StrongPanelCardStyle}"
                                CornerRadius="18"
                                Padding="34"
                                Width="1050"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="{Binding CurrentAnnouncement.Title}"
                                           Style="{StaticResource DisplayTitleTextStyle}"
                                           TextAlignment="Center"
                                           Margin="0,0,0,26"/>

                                <Image Source="{Binding CurrentAnnouncement.ImagePath, Converter={StaticResource ImagePathToBitmapConverter}}"
                                    MaxHeight="400"
                                    Stretch="Uniform"
                                    Margin="0,0,0,24">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Source, RelativeSource={RelativeSource Self}}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>

                                <TextBlock Text="{Binding CurrentAnnouncement.BodyText}"
                                           Style="{StaticResource DisplayLargeBodyTextStyle}"
                                           LineHeight="50"
                                           TextWrapping="Wrap"
                                           TextAlignment="Left"
                                           Opacity="0.95"/>

                            </StackPanel>
                        </Border>

                    </Grid>
                </Grid>


                <!-- ================= BOTTOM BANNER ================= -->
                <Grid Grid.Row="2" Margin="0,12,0,0">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Settings.ShowBanner}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Settings.BannerPosition}" Value="Top">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Settings.BannerText}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <StackPanel>
                        <!-- Separator line -->
                        <Border Height="2"
                            Background="{StaticResource DisplaySeparatorBrush}"
                            HorizontalAlignment="Stretch"/>

                        <!-- Banner text -->
                        <TextBlock Text="{Binding Settings.BannerText}"
                                   Style="{StaticResource DisplayBannerTextStyle}"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>

        </Grid>


        <!-- ================= PHOTO ================= -->
        <Grid Visibility="{Binding IsPhotoVisible, Converter={StaticResource BoolToVisibility}}"
              Background="Black">

            <Image Source="{Binding CurrentPhoto.ImagePath, Converter={StaticResource ImagePathToBitmapConverter}}"
                        Stretch="Uniform">
                <Image.Style>
                    <Style TargetType="Image">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPhotoFallbackVisible}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Source, RelativeSource={RelativeSource Self}}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Image.Style>
            </Image>

            <!-- Fallback if photos aren't available. -->
            <Border Background="#AA111111"
                        CornerRadius="12"
                        Padding="30"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPhotoFallbackVisible}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <StackPanel>
                    <TextBlock Text="No Active Photos"
                               Style="{StaticResource DisplayBodyTextStyle}"
                               HorizontalAlignment="Center" />

                    <TextBlock Text="Add photos or mark existing photos as Active."
                               Style="{StaticResource DisplayTinyTextStyle}"
                               Margin="0,10,0,0"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- bottom caption overlay -->
            <Border VerticalAlignment="Bottom"
                            Height="180">

                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasCurrentPhotoText}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#00000000" Offset="0"/>
                        <GradientStop Color="#77000000" Offset="0.35" />
                        <GradientStop Color="#EE000000" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid VerticalAlignment="Stretch"
                              Margin="24">

                    <StackPanel VerticalAlignment="Bottom">

                        <TextBlock Text="{Binding CurrentPhoto.Caption}"
                                   Style="{StaticResource DisplayCaptionTextStyle}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,4"/>

                        <TextBlock Text="{Binding CurrentPhoto.Credit}"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock"
                                       BasedOn="{StaticResource DisplayLabelTextStyle}">
                                    <Setter Property="Foreground" Value="{StaticResource DisplayMutedTextBrush}" />
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPhoto.Credit}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentPhoto.Credit}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>




</Window>
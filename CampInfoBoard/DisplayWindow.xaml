<Window x:Class="CampInfoBoard.DisplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:CampInfoBoard.Converters"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="Black">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibility"/>
        <converters:ImagePathToBitmapConverter x:Key="ImagePathToBitmapConverter"/>
        <converters:UVIndexToBrushConverter x:Key="UVIndexToBrushConverter"/>
        <converters:ScheduleBackgroundConverter x:Key="ScheduleBackgroundConverter"/>
        <converters:ScheduleBorderConverter x:Key="ScheduleBorderConverter"/>

        <!-- Display text styles -->
        <Style x:Key="PanelCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#33000000"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="AccentLabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9AD0FF"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="PrimaryDisplayTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="34"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="SecondaryDisplayTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#DDFFFFFF"/>
            <Setter Property="FontSize" Value="18"/>
        </Style>

    </Window.Resources>

    <Grid>

        <!-- ================= BACKGROUND ================= -->
        <Image Source="{Binding BackgroundImagePath}"
               Stretch="UniformToFill"
               Opacity="0.5"/>

        <!-- readability overlay -->
        <Rectangle Fill="Black" Opacity="0.45"/>

        <!-- ================= MAIN LAYOUT ================= -->
        <Grid Margin="32">

            <Grid.ColumnDefinitions>
                <!-- LEFT INFO STRIP -->
                <ColumnDefinition Width="420"/>
                <!-- MAIN CONTENT -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ================= LEFT PANEL ================= -->
            <StackPanel Grid.Column="0"
                        VerticalAlignment="Top">

                <!-- TIME (ANCHOR) -->
                <Border Style="{StaticResource PanelCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding CurrentTime, StringFormat='{}{0:dddd, MMMM d}'}"
                                   FontSize="24"
                                   Foreground="White"
                                   Opacity="0.75"/>

                        <TextBlock Text="{Binding CurrentTime, StringFormat='{}{0:h:mm tt}'}"
                                   FontSize="52"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                    </StackPanel>
                </Border>

                
                <!-- WEATHER BLOCK -->
                <Border Style="{StaticResource PanelCardStyle}">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding DisplayWeather}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="84"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="70"/>
                                        </Grid.ColumnDefinitions>

                                        <Image Grid.Column="0"
                                            Source="{Binding IconPath}"
                                            Width="72"
                                            Height="72"
                                            Margin="0,0,10,0"/>

                                        <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DateLabel}"
                                                FontSize="18"
                                                Foreground="#9AD0FF"
                                                FontWeight="SemiBold"/>

                                            <TextBlock Text="{Binding TemperatureDisplay}"
                                                FontSize="28"
                                                FontWeight="SemiBold"
                                                Foreground="White"/>

                                            <TextBlock Text="{Binding FeelsLikeDisplay}"
                                                FontSize="20"
                                                Foreground="#DDFFFFFF"
                                                Opacity="0.75"
                                                Visibility="{Binding HasFeelsLike, Converter={StaticResource BoolToVisibility}}"/>
                                        </StackPanel>

                                        <Border Grid.Column="2"
                                            Width="64"
                                            Height="64"
                                            CornerRadius="32"
                                            Background="{Binding UVIndex, Converter={StaticResource UVIndexToBrushConverter}}"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Right"
                                            Visibility="{Binding HasUV, Converter={StaticResource BoolToVisibility}}">
                                            <StackPanel HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                                <TextBlock Text="UV"
                                                    FontSize="14"
                                                    FontWeight="Bold"
                                                    Foreground="Black"
                                                    HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding UVIndex}"
                                                    FontSize="32"
                                                    FontWeight="Bold"
                                                    Foreground="Black"
                                                    HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                
                <!-- SUN TIMES -->
                <Border Style="{StaticResource PanelCardStyle}">
                    <StackPanel>
                        <StackPanel Visibility="{Binding Settings.ShowSun, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,4">
                                <Image Source="pack://application:,,,/Assets/WeatherIcons/sunrise.png"
                                    Width="64"
                                    Height="48"
                                    Margin="0,0,14,0"/>
                                <TextBlock Text="{Binding TodaySun.Sunrise, StringFormat={}{0:h:mm tt}}"
                                    FontSize="26"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <Image Source="pack://application:,,,/Assets/WeatherIcons/sunset.png"
                                    Width="64"
                                    Height="48"
                                    Margin="0,0,14,0"/>
                                <TextBlock Text="{Binding TodaySun.Sunset, StringFormat={}{0:h:mm tt}}"
                                    FontSize="26"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>


                <!-- TIDES -->
                <Border Style="{StaticResource PanelCardStyle}">
                    <ItemsControl ItemsSource="{Binding DisplayTides}"
                        Visibility="{Binding Settings.ShowTides, Converter={StaticResource BoolToVisibility}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <TextBlock Text="{Binding SeparatorLabel}"
                                        FontSize="20"
                                        FontWeight="SemiBold"
                                        Foreground="#9AD0FF">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,4">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <Image Source="{Binding IconPath}"
                                            Width="64"
                                            Height="48"
                                            Margin="0,0,14,0"/>
                                        <TextBlock Text="{Binding TimeDisplay}"
                                            FontSize="26"
                                            FontWeight="SemiBold"
                                            Foreground="White"
                                            VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>


                <!-- RADIO FREQUENCIES -->
                <Border Style="{StaticResource PanelCardStyle}">
                    <StackPanel
                        Visibility="{Binding Radio.Enabled, Converter={StaticResource BoolToVisibility}}">
                        <!-- RADIO -->
                        <StackPanel Visibility="{Binding Radio.Enabled, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="FM Radio"
                                   FontSize="18"
                                   Foreground="White"
                                   Opacity="0.75"
                                   Margin="0,0,0,6"/>

                            <TextBlock Text="{Binding Radio.EnglishFrequency, StringFormat='EN {0} MHz'}"
                                   Foreground="White"
                                   FontSize="26"
                                   FontWeight="SemiBold"
                                   Visibility="{Binding Radio.EnglishFrequency, Converter={StaticResource NullToVisibility}}"/>

                            <TextBlock Text="{Binding Radio.FrenchFrequency, StringFormat='FR {0} MHz'}"
                                   Foreground="White"
                                   FontSize="26"
                                   FontWeight="SemiBold"
                                   Visibility="{Binding Radio.FrenchFrequency, Converter={StaticResource NullToVisibility}}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
                

            <!-- ================= MAIN CONTENT AREA ================= -->
            <Grid Grid.Column="1"
                  Margin="40,0,0,0">

                <!-- ================= SCHEDULE ================= -->
                <Grid Visibility="{Binding IsScheduleVisible, Converter={StaticResource BoolToVisibility}}">

                    <ScrollViewer VerticalScrollBarVisibility="Hidden">
                        <ItemsControl ItemsSource="{Binding FilteredSchedule}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,10"
                                            Padding="16"
                                            Background="{Binding IsHappeningNow, Converter={StaticResource ScheduleBackgroundConverter}}"
                                            BorderBrush="{Binding IsHappeningNow, Converter={StaticResource ScheduleBorderConverter}}"
                                            BorderThickness="3"
                                            CornerRadius="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="190"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- TIME -->
                                            <StackPanel Grid.Column="0"
                                                VerticalAlignment="Top">
                                                <TextBlock Text="{Binding DisplayDayLabel}"
                                                    FontSize="24"
                                                    FontWeight="SemiBold"
                                                    Foreground="#9AD0FF"/>

                                                <TextBlock Text="{Binding DisplayStartTime}"
                                                    FontSize="40"
                                                    FontWeight="Bold"
                                                    Foreground="White"
                                                    Margin="0,4,0,0"/>

                                                <TextBlock Text="{Binding DisplayEndTime}"
                                                    FontSize="24"
                                                    Foreground="#CCFFFFFF"
                                                    Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <!-- DETAILS -->
                                            <StackPanel Grid.Column="1"
                                                Margin="20,0,0,0">

                                                <TextBlock Text="{Binding Title}"
                                                    FontSize="54"
                                                    FontWeight="SemiBold"
                                                    Foreground="White"/>

                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Location}"
                                                        FontSize="30"
                                                        Foreground="#9AD0FF"
                                                        Margin="0,6,24,0"/>

                                                    <TextBlock Text="{Binding Speaker}"
                                                        FontSize="30"
                                                        Foreground="#DDFFFFFF"
                                                        Margin="0,6,24,0"/>
                                                </StackPanel>
                                                
                                                <TextBlock Text="{Binding Description}"
                                                    FontSize="36"
                                                    Foreground="White"
                                                    TextWrapping="Wrap"
                                                    Margin="0,10,0,0"
                                                    Opacity="0.95"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                </Grid>


                <!-- ================= WEATHER ================= -->
                <Grid Visibility="{Binding IsWeatherVisible, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel VerticalAlignment="Top"
                        HorizontalAlignment="Center"
                        Width="1100">

                        <ItemsControl ItemsSource="{Binding DisplayWeather}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,10"
                                        Padding="28"
                                        Background="#33000000"
                                        CornerRadius="14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="150"/>
                                            </Grid.ColumnDefinitions>

                                            <Image Grid.Column="0"
                                                Source="{Binding IconPath}"
                                                Width="152"
                                                Height="152"
                                                VerticalAlignment="Top"/>

                                            <StackPanel Grid.Column="1"
                                                Margin="20,0,0,0">

                                                <TextBlock Text="{Binding DateLabel}"
                                                    FontSize="24"
                                                    FontWeight="SemiBold"
                                                    Foreground="#9AD0FF"/>

                                                <TextBlock Text="{Binding TemperatureDisplay}"
                                                    FontSize="48"
                                                    FontWeight="Bold"
                                                    Foreground="White"/>

                                                <TextBlock Text="{Binding FeelsLikeDisplay}"
                                                    FontSize="32"
                                                    Foreground="LightGray"
                                                    Visibility="{Binding HasFeelsLike, Converter={StaticResource BoolToVisibility}}"/>

                                                <TextBlock Text="{Binding Description}"
                                                    FontSize="36"
                                                    Foreground="White"
                                                    FontWeight="SemiBold"
                                                    TextWrapping="Wrap"/>

                                                <TextBlock Text="{Binding WindDisplay}"
                                                    FontSize="26"
                                                    Foreground="LightGray"
                                                    Visibility="{Binding HasWind, Converter={StaticResource BoolToVisibility}}"/>

                                                <TextBlock Text="{Binding PrecipitationDisplay}"
                                                    FontSize="26"
                                                    Foreground="LightGray"
                                                    Visibility="{Binding PrecipitationDisplay, Converter={StaticResource NullToVisibility}}"/>
                                            </StackPanel>

                                            <Border Grid.Column="2"
                                                Width="116"
                                                Height="116"
                                                CornerRadius="58"
                                                Background="{Binding UVIndex, Converter={StaticResource UVIndexToBrushConverter}}"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right"
                                                Visibility="{Binding HasUV, Converter={StaticResource BoolToVisibility}}">
                                                <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                                    <TextBlock Text="UV"
                                                        FontSize="22"
                                                        FontWeight="Bold"
                                                        Foreground="Black"
                                                        HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding UVIndex}"
                                                        FontSize="46"
                                                        FontWeight="Bold"
                                                        Foreground="Black"
                                                        HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
                
                
                <!-- ================= ANNOUNCEMENTS ================= -->
                <Grid Visibility="{Binding IsAnnouncementVisible, Converter={StaticResource BoolToVisibility}}">

                    <StackPanel VerticalAlignment="Top"
                                HorizontalAlignment="Center"
                                Width="900">

                        <TextBlock Text="{Binding CurrentAnnouncement.Title}"
                                   FontSize="40"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   TextAlignment="Center"
                                   Margin="0,0,0,20"/>

                        <Image Source="{Binding CurrentAnnouncement.ImagePath}"
                               Height="260"
                               Stretch="Uniform"
                               Margin="0,0,0,20"/>

                        <TextBlock Text="{Binding CurrentAnnouncement.BodyText}"
                                   FontSize="26"
                                   Foreground="White"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Opacity="0.95"/>

                    </StackPanel>

                </Grid>

                
                <!-- ================= PHOTO ================= -->
                <Grid Visibility="{Binding IsPhotoVisible, Converter={StaticResource BoolToVisibility}}">

                    <Image Source="{Binding CurrentPhoto.ImagePath, Converter={StaticResource ImagePathToBitmapConverter}}"
                        Stretch="Uniform">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPhotoFallbackVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>

                    <!-- Fallback if photos aren't available. -->
                    <Border Background="#AA111111"
                        CornerRadius="12"
                        Padding="30"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPhotoFallbackVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <StackPanel>
                            <TextBlock Text="No Active Photos"
                                Foreground="White"
                                FontSize="36"
                                FontWeight="Bold"
                                HorizontalAlignment="Center" />

                            <TextBlock Text="Add photos or mark existing photos as Active."
                                Foreground="#DDFFFFFF"
                                FontSize="18"
                                Margin="0,10,0,0"
                                HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- bottom caption overlay -->
                    <Border VerticalAlignment="Bottom"
                            Height="180">

                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasCurrentPhotoText}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#00000000" Offset="0"/>
                                <GradientStop Color="#88000000" Offset="0.25" />
                                <GradientStop Color="#EE000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>

                        <Grid VerticalAlignment="Stretch"
                              Margin="24">

                            <StackPanel VerticalAlignment="Bottom">

                                <TextBlock Text="{Binding CurrentPhoto.Caption}"
                                    FontSize="30"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    TextWrapping="Wrap"/>

                                <TextBlock Text="{Binding CurrentPhoto.Credit}"
                                    FontSize="16"
                                    Foreground="#DDFFFFFF"
                                    Margin="0,6,0,0"
                                    TextWrapping="Wrap">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentPhoto.Credit}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding CurrentPhoto.Credit}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>

                </Grid>

            </Grid>

        </Grid>
    </Grid>
</Window>
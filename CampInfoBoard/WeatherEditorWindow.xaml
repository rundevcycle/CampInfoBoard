<Window x:Class="CampInfoBoard.WeatherEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Weather"
        Height="460"
        Width="520"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Date" Margin="0,0,8,8"/>
            <DatePicker Grid.Column="1"
                        SelectedDate="{Binding Date}"
                        Margin="0,0,0,8"/>

            <TextBlock Grid.Row="1" Text="Period" Margin="0,0,8,8"/>
            <ComboBox Grid.Row="1"
                      Grid.Column="1"
                      ItemsSource="{Binding WeatherPeriods}"
                      SelectedItem="{Binding Weather.Period}"
                      Margin="0,0,0,8"/>

            <TextBlock Grid.Row="2" Text="Temperature °C" Margin="0,0,8,8"/>
            <TextBox Grid.Row="2" Grid.Column="1"
                     Text="{Binding Weather.TemperatureC, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,8"/>

            <TextBlock Grid.Row="3" Text="Feels Like °C" Margin="0,0,8,8"/>
            <TextBox Grid.Row="3" Grid.Column="1"
                     Text="{Binding Weather.FeelsLikeC, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,8"/>

            <TextBlock Grid.Row="4" Text="Wind km/h" Margin="0,0,8,8" VerticalAlignment="Center"/>
            <Grid Grid.Row="4"
                Grid.Column="1"
                Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="70"/>
                </Grid.ColumnDefinitions>

                <!-- Wind Speed -->
                <TextBox Grid.Column="0"
                    Text="{Binding Weather.WindSpeedKph, UpdateSourceTrigger=PropertyChanged}"
                    Margin="0,0,8,0"
                    VerticalContentAlignment="Center"/>

                <!-- Wind Direction -->
                <ComboBox Grid.Column="1"
                    ItemsSource="{Binding WindDirections}"
                    SelectedItem="{Binding Weather.WindDirectionValue}"
                    Margin="0,0,8,0"/>

                <!-- Gust Label -->
                <TextBlock Grid.Column="2"
                    Text="gusts"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"/>

                <!-- Gust Speed -->
                <TextBox Grid.Column="3"
                    Text="{Binding Weather.WindGustKph, UpdateSourceTrigger=PropertyChanged}"
                    VerticalContentAlignment="Center"/>
            </Grid>

            <TextBlock Grid.Row="5" Text="UV Index" Margin="0,0,8,8"/>
            <TextBox Grid.Row="5" Grid.Column="1"
                     Text="{Binding Weather.UVIndex, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,8"/>

            <TextBlock Grid.Row="6" Text="Precipitation" Margin="0,0,8,8"/>
            <TextBox Grid.Row="6" Grid.Column="1"
                     Text="{Binding Weather.PrecipitationDisplay}"
                     Margin="0,0,0,8"/>

            <TextBlock Grid.Row="7" Text="Icon" Margin="0,0,8,8"/>
            <TextBox Grid.Row="7" Grid.Column="1"
                     Text="{Binding Weather.Icon}"
                     Margin="0,0,0,8"/>

            <TextBlock Grid.Row="8" Text="Description" Margin="0,0,8,0"/>
            <TextBox Grid.Row="8" Grid.Column="1"
                     Text="{Binding Weather.Description}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"/>
        </Grid>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="OK"
                    Width="90"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="Ok_Click"/>

            <Button Content="Cancel"
                    Width="90"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
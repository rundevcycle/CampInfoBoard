<Window x:Class="CampInfoBoard.ControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Camp Info Board Control"
        Width="1100"
        Height="750"
        Closing="Window_Closing">

    <DockPanel Margin="12">

        <!-- Top Buttons -->
        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Margin="0,0,0,12">

            <Button x:Name="DisplayToggleButton"
                    Content="Show Display"
                    Width="120"
                    Margin="0,0,8,0"
                    Click="DisplayToggle_Click"/>

            <Button Content="Refresh Display"
                    Width="120"
                    Margin="0,0,8,0"
                    Click="RefreshDisplay_Click"/>

            <Button Content="Save"
                    Width="100"
                    Margin="0,0,8,0"
                    Click="Save_Click"/>

            <Button Content="Reload"
                    Width="100"
                    Click="Reload_Click"/>
        </StackPanel>

        <TabControl>

            <TabItem Header="Dashboard">
                <StackPanel Margin="12" Width="500" HorizontalAlignment="Left">

                    <TextBlock Text="UV Display"/>
                    <TextBox Text="{Binding Data.UVDisplay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="Sunrise"/>
                    <TextBox Text="{Binding Data.Sun.SunriseDisplay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="Sunset"/>
                    <TextBox Text="{Binding Data.Sun.SunsetDisplay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <CheckBox Content="Show tides"
                              IsChecked="{Binding Data.Settings.ShowTides}"
                              Margin="0,0,0,8"/>

                    <CheckBox Content="Show sun"
                              IsChecked="{Binding Data.Settings.ShowSun}"
                              Margin="0,0,0,8"/>

                    <CheckBox Content="Show UV"
                              IsChecked="{Binding Data.Settings.ShowUV}"
                              Margin="0,0,0,16"/>

                    <CheckBox Content="FM Broadcast Enabled"
                              IsChecked="{Binding Data.Radio.Enabled}"
                              Margin="0,0,0,8"/>

                    <TextBlock Text="English FM Frequency"/>
                    <TextBox Text="{Binding Data.Radio.EnglishFrequency, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="French FM Frequency"/>
                    <TextBox Text="{Binding Data.Radio.FrenchFrequency, UpdateSourceTrigger=PropertyChanged}"/>

                </StackPanel>
            </TabItem>

            <TabItem Header="Tides">
                <DockPanel Margin="12">

                    <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Margin="0,0,0,8">
                        
                        <Button Content="Add Tide"
                            Width="100"
                            Margin="0,0,8,0"
                            Click="AddTide_Click"/>
                        <Button Content="Alternate From Selected"
                            Width="190"
                            Margin="0,0,8,0"
                            Click="RecalculateTidesFromSelected_Click"/>

                        <Button Content="Delete Past Tides"
                            Width="140"
                            Click="DeletePastTides_Click"/>

                    </StackPanel>

                    <DataGrid x:Name="TideGrid"
                        ItemsSource="{Binding Data.TideEntries}"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        CanUserDeleteRows="True"
                        PreviewKeyDown="TideGrid_PreviewKeyDown">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Date" Width="190">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Date, StringFormat={}{0:d}}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>

                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <DockPanel>
                                            <Button Content="📅"
                                                DockPanel.Dock="Right"
                                                Width="32"
                                                Margin="4,0,0,0"
                                                Click="PickTideDate_Click"/>
                                            <TextBox Text="{Binding DateText, UpdateSourceTrigger=LostFocus}"
                                                VerticalContentAlignment="Center"
                                                Loaded="EditingTextBox_Loaded"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Time"
                        Binding="{Binding TimeText, UpdateSourceTrigger=LostFocus}"
                        Width="120"/>

                            <DataGridTextColumn Header="High / Low"
                        Binding="{Binding TideLevel, UpdateSourceTrigger=PropertyChanged}"
                        Width="140"/>

                        </DataGrid.Columns>
                    </DataGrid>

                </DockPanel>
            </TabItem>

            <TabItem Header="Schedule">
                <DockPanel Margin="12">

                    <StackPanel DockPanel.Dock="Top"
                        Orientation="Horizontal"
                        Margin="0,0,0,8">

                        <Button Content="Add Event"
                            Width="100"
                            Margin="0,0,8,0"
                            Click="AddScheduleItem_Click"/>

                        <Button Content="Copy Event"
                            Width="100"
                            Margin="0,0,8,0"
                            Click="CopyScheduleItem_Click"/>

                        <Button Content="Edit Event"
                            Width="100"
                            Margin="0,0,8,0"
                            Click="EditScheduleItem_Click"/>

                        <Button Content="Delete Event"
                            Width="100"
                            Click="DeleteScheduleItem_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="ScheduleGrid"
                        ItemsSource="{Binding ScheduleView}"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        CanUserDeleteRows="False"
                        IsReadOnly="True"
                        SelectionMode="Single"
                        MouseDoubleClick="ScheduleGrid_MouseDoubleClick">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Start"
                                    Binding="{Binding Start, StringFormat=g}"
                                    Width="150"/>

                            <DataGridTextColumn Header="End"
                                    Binding="{Binding End, StringFormat=g}"
                                    Width="150"/>

                            <DataGridTextColumn Header="Title"
                                    Binding="{Binding Title}"
                                    Width="*"/>

                            <DataGridTextColumn Header="Location"
                                    Binding="{Binding Location}"
                                    Width="160"/>

                            <DataGridTextColumn Header="Speaker"
                                    Binding="{Binding Speaker}"
                                    Width="160"/>
                        </DataGrid.Columns>

                    </DataGrid>
                </DockPanel>
            </TabItem>


            <TabItem Header="Announcements">
                <DockPanel Margin="12">

                    <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Margin="0,0,0,8">

                        <Button Content="Add Announcement"
                    Width="140"
                    Margin="0,0,8,0"
                    Click="AddAnnouncement_Click"/>

                        <Button Content="Copy Announcement"
                    Width="150"
                    Margin="0,0,8,0"
                    Click="CopyAnnouncement_Click"/>

                        <Button Content="Edit Announcement"
                    Width="150"
                    Margin="0,0,8,0"
                    Click="EditAnnouncement_Click"/>

                        <Button Content="Delete Announcement"
                    Width="150"
                    Click="DeleteAnnouncement_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="AnnouncementGrid"
                  ItemsSource="{Binding Data.Announcements}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  MouseDoubleClick="AnnouncementGrid_MouseDoubleClick">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Priority"
                                    Binding="{Binding Priority}"
                                    Width="80"/>

                            <DataGridTextColumn Header="Start"
                                    Binding="{Binding Start, StringFormat=g}"
                                    Width="150"/>

                            <DataGridTextColumn Header="End"
                                    Binding="{Binding End, StringFormat=g}"
                                    Width="150"/>

                            <DataGridTextColumn Header="Title"
                                    Binding="{Binding Title}"
                                    Width="*"/>

                            <DataGridTextColumn Header="Image"
                                    Binding="{Binding ImagePath}"
                                    Width="220"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
            <TabItem Header="Photos">
                <DataGrid ItemsSource="{Binding Data.Photos}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="True"
                          CanUserDeleteRows="True"
                          Margin="12">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Image Path" Binding="{Binding ImagePath}" Width="260"/>
                        <DataGridTextColumn Header="Caption" Binding="{Binding Caption}" Width="*"/>
                        <DataGridTextColumn Header="Credit" Binding="{Binding Credit}" Width="180"/>
                        <DataGridTextColumn Header="Added" Binding="{Binding Added, StringFormat=g}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
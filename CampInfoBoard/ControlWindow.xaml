<Window x:Class="CampInfoBoard.ControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Camp Info Board Control"
        Width="1100"
        Height="750"
        Closing="Window_Closing">

    <DockPanel Margin="12">

        <!-- Top Buttons -->
        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Margin="0,0,0,12">

            <Button x:Name="DisplayToggleButton"
                    Content="Show Display"
                    Width="120"
                    Margin="0,0,8,0"
                    Click="DisplayToggle_Click"/>

            <Button Content="Refresh Display"
                    Width="120"
                    Margin="0,0,8,0"
                    Click="RefreshDisplay_Click"/>

            <Button Content="Save"
                    Width="100"
                    Margin="0,0,8,0"
                    Click="Save_Click"/>

            <Button Content="Reload"
                    Width="100"
                    Click="Reload_Click"/>
        </StackPanel>

        <TabControl>

            <TabItem Header="Dashboard">
                <StackPanel Margin="12" Width="500" HorizontalAlignment="Left">

                    <TextBlock Text="UV Display"/>
                    <TextBox Text="{Binding Data.UVDisplay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="Sunrise"/>
                    <TextBox Text="{Binding Data.Sun.SunriseDisplay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="Sunset"/>
                    <TextBox Text="{Binding Data.Sun.SunsetDisplay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <CheckBox Content="Show tides"
                              IsChecked="{Binding Data.Settings.ShowTides}"
                              Margin="0,0,0,8"/>

                    <CheckBox Content="Show sun"
                              IsChecked="{Binding Data.Settings.ShowSun}"
                              Margin="0,0,0,8"/>

                    <CheckBox Content="Show UV"
                              IsChecked="{Binding Data.Settings.ShowUV}"
                              Margin="0,0,0,16"/>

                    <CheckBox Content="FM Broadcast Enabled"
                              IsChecked="{Binding Data.Radio.Enabled}"
                              Margin="0,0,0,8"/>

                    <TextBlock Text="English FM Frequency"/>
                    <TextBox Text="{Binding Data.Radio.EnglishFrequency, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="French FM Frequency"/>
                    <TextBox Text="{Binding Data.Radio.FrenchFrequency, UpdateSourceTrigger=PropertyChanged}"/>

                </StackPanel>
            </TabItem>

            <TabItem Header="Tides">
                <DataGrid ItemsSource="{Binding Data.TideEntries}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="True"
                          CanUserDeleteRows="True"
                          Margin="12">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time"
                                            Binding="{Binding Time, StringFormat=g}" Width="*" />

                        <DataGridComboBoxColumn Header="High / Low"
                                                SelectedItemBinding="{Binding TideLevel}"
                                                Width="160">
                            <DataGridComboBoxColumn.ItemsSource>
                                <x:Array Type="{x:Type sys:String}">
                                    <sys:String>High</sys:String>
                                    <sys:String>Low</sys:String>
                                </x:Array>
                            </DataGridComboBoxColumn.ItemsSource>
                        </DataGridComboBoxColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Schedule">
                <DataGrid ItemsSource="{Binding Data.Schedule}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="True"
                          CanUserDeleteRows="True"
                          Margin="12">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Start" Binding="{Binding Start, StringFormat=g}" Width="150"/>
                        <DataGridTextColumn Header="End" Binding="{Binding End, StringFormat=g}" Width="150"/>
                        <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="180"/>
                        <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="140"/>
                        <DataGridTextColumn Header="Speaker" Binding="{Binding Speaker}" Width="140"/>
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Announcements">
                <DataGrid ItemsSource="{Binding Data.Announcements}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="True"
                          CanUserDeleteRows="True"
                          Margin="12">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Priority" Binding="{Binding Priority}" Width="80"/>
                        <DataGridTextColumn Header="Start" Binding="{Binding Start, StringFormat=g}" Width="150"/>
                        <DataGridTextColumn Header="End" Binding="{Binding End, StringFormat=g}" Width="150"/>
                        <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="200"/>
                        <DataGridTextColumn Header="Body" Binding="{Binding BodyText}" Width="*"/>
                        <DataGridTextColumn Header="Image Path" Binding="{Binding ImagePath}" Width="220"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Photos">
                <DataGrid ItemsSource="{Binding Data.Photos}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="True"
                          CanUserDeleteRows="True"
                          Margin="12">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Image Path" Binding="{Binding ImagePath}" Width="260"/>
                        <DataGridTextColumn Header="Caption" Binding="{Binding Caption}" Width="*"/>
                        <DataGridTextColumn Header="Credit" Binding="{Binding Credit}" Width="180"/>
                        <DataGridTextColumn Header="Added" Binding="{Binding Added, StringFormat=g}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
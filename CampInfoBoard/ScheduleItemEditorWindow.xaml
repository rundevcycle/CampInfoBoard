<Window x:Class="CampInfoBoard.ScheduleItemEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Schedule Event"
        Width="650"
        Height="560"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">

    <DockPanel Margin="16">

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">

            <Button Content="Save &amp; New"
                    Width="90"
                    Margin="0,0,8,0"
                    Click="SaveAndNew_Click"/>

            <Button Content="Save &amp; Done"
                    Width="90"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="Ok_Click"/>

            <Button Content="Cancel"
                    Width="90"
                    IsCancel="True"/>
        </StackPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="Start Date"
                       VerticalAlignment="Center"
                       Margin="0,0,8,8"/>

            <TextBox Grid.Row="0" Grid.Column="1"
                     x:Name="StartDateBox"
                     Text="{Binding StartDateText, UpdateSourceTrigger=LostFocus}"
                     GotKeyboardFocus="TextBox_GotKeyboardFocus"
                     PreviewMouseLeftButtonDown="TextBox_PreviewMouseLeftButtonDown"
                     Margin="0,0,16,8"/>

            <TextBlock Grid.Row="0" Grid.Column="2"
                       Text="Start Time"
                       VerticalAlignment="Center"
                       Margin="0,0,8,8"/>

            <TextBox Grid.Row="0" Grid.Column="3"
                     Text="{Binding StartTimeText, UpdateSourceTrigger=LostFocus}"
                     GotKeyboardFocus="TextBox_GotKeyboardFocus"
                     PreviewMouseLeftButtonDown="TextBox_PreviewMouseLeftButtonDown"
                     Margin="0,0,0,8"/>

            <TextBlock Grid.Row="1" Grid.Column="0"
                       Text="End Date"
                       VerticalAlignment="Center"
                       Margin="0,0,8,8"/>

            <TextBox Grid.Row="1" Grid.Column="1"
                     Text="{Binding EndDateText, UpdateSourceTrigger=LostFocus}"
                     GotKeyboardFocus="TextBox_GotKeyboardFocus"
                     PreviewMouseLeftButtonDown="TextBox_PreviewMouseLeftButtonDown"
                     Margin="0,0,16,8"/>

            <TextBlock Grid.Row="1" Grid.Column="2"
                       Text="End Time"
                       VerticalAlignment="Center"
                       Margin="0,0,8,8"/>

            <TextBox Grid.Row="1" Grid.Column="3"
                     Text="{Binding EndTimeText, UpdateSourceTrigger=LostFocus}"
                     GotKeyboardFocus="TextBox_GotKeyboardFocus"
                     PreviewMouseLeftButtonDown="TextBox_PreviewMouseLeftButtonDown"
                     Margin="0,0,0,8"/>

            <TextBlock Grid.Row="2" Grid.Column="0"
                       Text="Title"
                       VerticalAlignment="Center"
                       Margin="0,0,8,8"/>

            <TextBox Grid.Row="2" Grid.Column="1"
                     Grid.ColumnSpan="3"
                     Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                     GotKeyboardFocus="TextBox_GotKeyboardFocus"
                     PreviewMouseLeftButtonDown="TextBox_PreviewMouseLeftButtonDown"
                     Margin="0,0,0,8"/>

            <TextBlock Grid.Row="3" Grid.Column="0"
                       Text="Location"
                       VerticalAlignment="Center"
                       Margin="0,0,8,8"/>

            <TextBox Grid.Row="3" Grid.Column="1"
                     Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}"
                     GotKeyboardFocus="TextBox_GotKeyboardFocus"
                     PreviewMouseLeftButtonDown="TextBox_PreviewMouseLeftButtonDown"
                     Margin="0,0,16,8"/>

            <TextBlock Grid.Row="3" Grid.Column="2"
                       Text="Speaker"
                       VerticalAlignment="Center"
                       Margin="0,0,8,8"/>

            <TextBox Grid.Row="3" Grid.Column="3"
                     Text="{Binding Speaker, UpdateSourceTrigger=PropertyChanged}"
                     GotKeyboardFocus="TextBox_GotKeyboardFocus"
                     PreviewMouseLeftButtonDown="TextBox_PreviewMouseLeftButtonDown"
                     Margin="0,0,0,8"/>

            <TextBlock Grid.Row="4" Grid.Column="0"
                       Text="Description"
                       VerticalAlignment="Top"
                       Margin="0,4,8,8"/>

            <TextBox Grid.Row="4" Grid.Column="1"
                     Grid.ColumnSpan="3"
                     Grid.RowSpan="2"
                     Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     MinHeight="180"/>
        </Grid>
    </DockPanel>
</Window>